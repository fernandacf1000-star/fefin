import type { Lancamento } from "@/hooks/useLancamentos";

export function genUUIDSafe(): string {
  if (typeof crypto !== "undefined" && typeof crypto.randomUUID === "function") {
    return crypto.randomUUID();
  }
  return `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
}

export function normalizeCategoria(categoria?: string | null) {
  const value = (categoria ?? "").trim().toLowerCase();
  if (!value || value === "extra") return "despesa";
  return value;
}

export function splitValor(total: number) {
  const principal = Math.round((total / 2) * 100) / 100;
  const espelho = Math.round((total - principal) * 100) / 100;
  return [principal, espelho] as const;
}

type SharedBaseParams = {
  descricao: string;
  valorTotal: number;
  categoria?: string | null;
  subcategoria?: string | null;
  categoria_macro?: string | null;
  forma_pagamento?: string | null;
  cartao_id?: string | null;
  data: string;
  mes_referencia: string;
  subcategoria_pais?: string | null;
  parcelamento_id?: string | null;
  parcela_atual?: number | null;
  parcela_total?: number | null;
  recorrente?: boolean;
  dia_recorrencia?: number | null;
  recorrencia_pai_id?: string | null;
  shared_group_id?: string | null;
};

export function buildPrincipalAndMirror(params: SharedBaseParams) {
  const [valorPrincipal, valorEspelho] = splitValor(params.valorTotal);
  const categoria = normalizeCategoria(params.categoria);
  const sharedGroupId = params.shared_group_id ?? genUUIDSafe();

  const principal = {
    descricao: params.descricao,
    valor: valorPrincipal,
    tipo: "despesa" as const,
    categoria,
    subcategoria: params.subcategoria ?? null,
    categoria_macro: params.categoria_macro ?? null,
    forma_pagamento: params.forma_pagamento ?? null,
    cartao_id: params.cartao_id ?? null,
    subcategoria_pais: params.subcategoria_pais ?? null,
    data: params.data,
    mes_referencia: params.mes_referencia,
    parcela_atual: params.parcela_atual ?? null,
    parcela_total: params.parcela_total ?? null,
    is_parcelado: !!params.parcelamento_id,
    parcelamento_id: params.parcelamento_id ?? null,
    pago: false,
    recorrente: !!params.recorrente,
    dia_recorrencia: params.dia_recorrencia ?? null,
    recorrencia_ate: null,
    recorrencia_pai_id: params.recorrencia_pai_id ?? null,
    adriano: false,
    shared_group_id: sharedGroupId,
    shared_role: "principal" as const,
  };

  const mirror = {
    descricao: params.descricao,
    valor: valorEspelho,
    tipo: "despesa" as const,
    categoria,
    subcategoria: params.subcategoria ?? null,
    categoria_macro: params.categoria_macro ?? null,
    forma_pagamento: params.forma_pagamento ?? null,
    cartao_id: params.cartao_id ?? null,
    subcategoria_pais: "Adriano",
    data: params.data,
    mes_referencia: params.mes_referencia,
    parcela_atual: params.parcela_atual ?? null,
    parcela_total: params.parcela_total ?? null,
    is_parcelado: !!params.parcelamento_id,
    parcelamento_id: params.parcelamento_id ?? null,
    pago: false,
    recorrente: !!params.recorrente,
    dia_recorrencia: params.dia_recorrencia ?? null,
    recorrencia_ate: null,
    recorrencia_pai_id: params.recorrencia_pai_id ?? null,
    adriano: true,
    shared_group_id: sharedGroupId,
    shared_role: "adriano" as const,
  };

  return { principal, mirror, sharedGroupId };
}

export function getLancamentoSharedState(lancamento?: Partial<Lancamento> | null) {
  if (!lancamento) return false;
  return !!lancamento.shared_group_id || !!lancamento.adriano;
}
